# Copy this file to `.env` and fill in the values, then run `docker compose up`.

# ---- Database (already wired into docker-compose) ----
POSTGRES_USER=anki
POSTGRES_PASSWORD=anki
POSTGRES_DB=anki

# ---- AI ----
# Option A) Use OpenAI directly with your own key:
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=sk-your-openai-key

# Option B) Use the Replit AI Integrations proxy (only works while running inside Replit
# or with valid Replit-issued credentials). In that case set both values to whatever
# `setupReplitAIIntegrations` provisioned for you.

# ---- Ports exposed on your host ----
WEB_PORT=5000
API_PORT=8080
DB_PORT=5432
